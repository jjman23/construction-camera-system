<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Camera Test - {{ camera.name }}</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: #000;
            color: #fff;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            overflow-x: hidden;
        }
        
        .test-header {
            background: #1a1a1a;
            padding: 10px 15px;
            border-bottom: 2px solid #333;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        
        .camera-selector {
            background: #2a2a2a;
            border: 1px solid #444;
            color: #fff;
            padding: 8px 12px;
            border-radius: 5px;
            width: 100%;
            max-width: 400px;
            font-size: 14px;
        }
        
        .video-wrapper {
            position: relative;
            width: 100%;
            height: calc(100vh - 120px);
            background: #000;
            overflow: hidden;
        }
        
        .video-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }
        
        .info-panel {
            background: #1a1a1a;
            padding: 15px;
            border-top: 2px solid #333;
            font-size: 12px;
        }
        
        .info-item {
            margin: 5px 0;
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            border-bottom: 1px solid #333;
        }
        
        .info-label {
            color: #888;
            font-weight: 500;
        }
        
        .info-value {
            color: #fff;
            font-family: monospace;
            word-break: break-all;
            text-align: right;
            max-width: 60%;
        }
        
        .status-badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 3px;
            font-size: 11px;
            font-weight: 600;
        }
        
        .status-success { background: #28a745; color: #fff; }
        .status-info { background: #17a2b8; color: #fff; }
        .status-warning { background: #ffc107; color: #000; }
        
        .action-buttons {
            display: flex;
            gap: 10px;
            margin-top: 10px;
            flex-wrap: wrap;
        }
        
        .btn-test {
            padding: 8px 16px;
            border: none;
            border-radius: 5px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .btn-primary { background: #007bff; color: #fff; }
        .btn-success { background: #28a745; color: #fff; }
        .btn-danger { background: #dc3545; color: #fff; }
        .btn-secondary { background: #6c757d; color: #fff; }
        
        .btn-test:active {
            transform: scale(0.95);
        }
        
        /* Mobile optimizations */
        @media (max-width: 768px) {
            .video-wrapper {
                height: calc(100vh - 140px);
            }
            
            .info-panel {
                font-size: 11px;
            }
            
            .info-value {
                font-size: 10px;
            }
        }
        
        /* Landscape mobile */
        @media (max-width: 768px) and (orientation: landscape) {
            .test-header {
                padding: 5px 10px;
            }
            
            .video-wrapper {
                height: 100vh;
            }
            
            .info-panel {
                display: none;
            }
        }
        
        .toggle-info {
            background: #2a2a2a;
            border: 1px solid #444;
            color: #fff;
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 12px;
            cursor: pointer;
        }
		
		.video-player {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			object-fit: contain;
			background: #000;
		}
    </style>
</head>
<body>
    <div class="test-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="flex-grow-1">
                <h6 class="mb-1">
                    <i class="bi bi-camera-video"></i> Camera Test
                </h6>
                <select class="camera-selector" onchange="window.location.href='/test/camera/' + this.value">
                    {% for cam in allCameras %}
                        <option value="{{ cam.id }}" {{ cam.id == camera.id ? 'selected' : '' }}>
                            {{ cam.building.name }} - {{ cam.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <button class="toggle-info" onclick="toggleInfo()">
                <i class="bi bi-info-circle"></i> Info
            </button>
        </div>
    </div>

    <div class="video-wrapper">
		{% if camera.rtspUrl %}
			<video 
				id="videoPlayer"
				class="video-player"
				controls
				autoplay
				muted
				playsinline
				preload="auto">
				<source src="{{ camera.rtspUrl }}" type="application/x-mpegURL">
			</video>
		{% else %}
			<div>No HLS stream URL configured</div>
		{% endif %}
	</div>

    <div class="info-panel" id="infoPanel">
        <h6 class="mb-3">
            <i class="bi bi-info-circle"></i> Debug Information
        </h6>
        
        <div class="info-item">
            <span class="info-label">Camera ID:</span>
            <span class="info-value">{{ camera.id }}</span>
        </div>
        
        <div class="info-item">
            <span class="info-label">Camera Name:</span>
            <span class="info-value">{{ camera.name }}</span>
        </div>
        
        <div class="info-item">
            <span class="info-label">Building:</span>
            <span class="info-value">{{ camera.building.name }}</span>
        </div>
        
        <div class="info-item">
            <span class="info-label">Stream URL:</span>
            <span class="info-value">
                {% if camera.rtspUrl %}
                    {{ camera.rtspUrl|slice(0, 100) }}...
                {% else %}
                    <span class="text-danger">Not set</span>
                {% endif %}
            </span>
        </div>
        
        <div class="info-item">
            <span class="info-label">Status:</span>
            <span class="info-value">
                {% if camera.active %}
                    <span class="status-badge status-success">Active</span>
                {% else %}
                    <span class="status-badge status-warning">Inactive</span>
                {% endif %}
                {% if camera.liveEnabled %}
                    <span class="status-badge status-info">Live Enabled</span>
                {% endif %}
            </span>
        </div>
        
        <div class="info-item">
            <span class="info-label">Screen Size:</span>
            <span class="info-value" id="screenSize">-</span>
        </div>
        
        <div class="info-item">
            <span class="info-label">Viewport:</span>
            <span class="info-value" id="viewport">-</span>
        </div>
        
        <div class="info-item">
            <span class="info-label">Device Type:</span>
            <span class="info-value" id="deviceType">-</span>
        </div>
        
        <div class="info-item">
            <span class="info-label">User Agent:</span>
            <span class="info-value" id="userAgent" style="font-size: 9px;">-</span>
        </div>

        <div class="action-buttons">
            <button class="btn-test btn-primary" onclick="window.location.reload()">
                <i class="bi bi-arrow-clockwise"></i> Reload
            </button>
            <button class="btn-test btn-success" onclick="testFullscreen()">
                <i class="bi bi-fullscreen"></i> Fullscreen
            </button>
            <button class="btn-test btn-secondary" onclick="copyUrl()">
                <i class="bi bi-clipboard"></i> Copy URL
            </button>
            {% if camera.building and camera.id %}
            <button class="btn-test btn-danger" onclick="window.location.href='{{ path('camera_live', {building_slug: camera.building.slug, camera_id: camera.id}) }}'">
                <i class="bi bi-box-arrow-up-right"></i> Production View
            </button>
            {% endif %}
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Update device info
        function updateDeviceInfo() {
            document.getElementById('screenSize').textContent = 
                screen.width + 'x' + screen.height;
            
            document.getElementById('viewport').textContent = 
                window.innerWidth + 'x' + window.innerHeight;
            
            const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
            const isTablet = /iPad|Android/i.test(navigator.userAgent) && window.innerWidth > 600;
            
            let deviceType = 'Desktop';
            if (isMobile && !isTablet) deviceType = 'Mobile';
            if (isTablet) deviceType = 'Tablet';
            
            document.getElementById('deviceType').textContent = deviceType;
            document.getElementById('userAgent').textContent = navigator.userAgent;
        }
        
        // Toggle info panel
        function toggleInfo() {
            const panel = document.getElementById('infoPanel');
            panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
        }
        
        // Test fullscreen
        function testFullscreen() {
            const wrapper = document.querySelector('.video-wrapper');
            if (wrapper.requestFullscreen) {
                wrapper.requestFullscreen();
            } else if (wrapper.webkitRequestFullscreen) {
                wrapper.webkitRequestFullscreen();
            } else if (wrapper.mozRequestFullScreen) {
                wrapper.mozRequestFullScreen();
            }
        }
        
        // Copy URL
        function copyUrl() {
            navigator.clipboard.writeText(window.location.href).then(() => {
                alert('URL copied to clipboard!');
            });
        }
        
        // Update on resize
        window.addEventListener('resize', updateDeviceInfo);
        window.addEventListener('orientationchange', updateDeviceInfo);
        
        // Initial update
        updateDeviceInfo();
        
        // Auto-hide info panel on mobile landscape
        if (window.matchMedia("(max-width: 768px) and (orientation: landscape)").matches) {
            document.getElementById('infoPanel').style.display = 'none';
        }
    </script>
	
	<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
	<script>
	const video = document.getElementById('videoPlayer');
	if (video && video.querySelector('source')) {
		const src = video.querySelector('source').src;
		
		// Check HLS.js support FIRST (for Chrome, Firefox, etc.)
		if (Hls.isSupported()) {
			console.log('Using HLS.js for playback');
			const hls = new Hls({
				enableWorker: true,
				lowLatencyMode: false
			});
			
			hls.loadSource(src);
			hls.attachMedia(video);
			
			hls.on(Hls.Events.MANIFEST_PARSED, function() {
				console.log('HLS manifest loaded, attempting play');
				video.play().catch(e => console.log('Autoplay blocked:', e));
			});
			
			hls.on(Hls.Events.ERROR, function(event, data) {
				console.error('HLS.js error:', data);
			});
			
		} else if (video.canPlayType('application/vnd.apple.mpegurl')) {
			// Native HLS support (Safari/iOS) - use as fallback
			console.log('Using native HLS (Safari)');
			video.src = src;
			video.play().catch(e => console.log('Autoplay blocked:', e));
		} else {
			console.error('HLS not supported in this browser');
		}
	}
	</script>
</body>
</html>
